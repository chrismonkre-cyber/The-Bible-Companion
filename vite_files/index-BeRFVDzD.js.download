Return 6-8 highly relevant verses. For each verse, provide the exact ${t} text and full reference.
If the query is a topic or theme, return the most well-known verses. Be accurate to the ${t} wording.`,response_json_schema:{type:"object",properties:{verses:{type:"array",items:{type:"object",properties:{reference:{type:"string"},text:{type:"string"}},required:["reference","text"]}}}}});u((x==null?void 0:x.verses)||[]),p(!1)},g=()=>{i(""),u(null),n&&n()};return f.jsxs("div",{children:[f.jsxs("div",{className:"flex gap-2 mb-4",children:[f.jsxs("div",{className:"relative flex-1",children:[f.jsx(dC,{className:"absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#8B8B8B]"}),f.jsx(fb,{value:o,onChange:v=>i(v.target.value),onKeyDown:v=>v.key==="Enter"&&m(),placeholder:'Search "John 3:16", "love", "faith"...',className:"pl-11 pr-10 h-12 bg-white border-2 border-[#E5C07B] rounded-xl font-serif text-sm focus:border-[#4A0404] focus:ring-[#4A0404]/10 shadow-sm"}),o&&f.jsx("button",{onClick:g,className:"absolute right-3 top-1/2 -translate-y-1/2 text-[#A0A0A0] hover:text-sage transition-colors",children:f.jsx(ms,{className:"w-4 h-4"})})]}),f.jsx(Bi,{onClick:m,disabled:d||!o.trim(),className:"bg-sage hover:bg-sage-dark text-cream rounded-xl px-5 h-11 font-serif text-sm",children:d?"...":"Search"})]}),d&&f.jsx("div",{className:"space-y-3 mt-4",children:[1,2,3].map(v=>f.jsx("div",{className:"h-16 bg-white/50 rounded-xl border border-[#E8E3D3] gentle-pulse"},v))}),l&&f.jsxs(ie.div,{initial:{opacity:0,y:10},animate:{opacity:1,y:0},className:"mt-2",children:[f.jsxs("div",{className:"flex items-center justify-between mb-3",children:[f.jsxs("p",{className:"font-serif text-xs text-[#8B8B8B]",children:[l.length," results in ",t]}),f.jsx("button",{onClick:g,className:"text-xs text-sage font-serif hover:underline",children:"Clear"})]}),f.jsx("div",{className:"space-y-3",children:l.map((v,x)=>f.jsxs("div",{className:"bg-white/50 rounded-xl p-4 border border-[#E8E3D3] hover:border-sage/40 transition-all",children:[f.jsxs("p",{className:"font-serif text-[#3D3D3D] leading-relaxed text-sm it