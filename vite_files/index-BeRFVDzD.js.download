md:py-14",children:f.jsxs("div",{className:"max-w-2xl mx-auto",children:[f.jsxs(ie.div,{initial:{opacity:0,y:20},animate:{opacity:1,y:0},transition:{duration:.5,delay:.2},className:"-mt-10 bg-[#4A0404] rounded-3xl p-8 md:p-12 border border-[#E5C07B]/40 shadow-xl mb-10",children:[f.jsx("div",{className:"flex justify-center mb-6",children:f.jsx("div",{className:"w-12 h-12 rounded-full border border-[#E5C07B]/50 flex items-center justify-center",children:f.jsx(Kk,{className:"w-5 h-5 text-[#E5C07B]"})})}),f.jsx("div",{className:"bg-[#3A0303] rounded-2xl p-5 mb-8 border border-[#E5C07B]/20",children:f.jsxs("p",{className:"font-serif text-[#E5C07B] text-sm md:text-base leading-relaxed text-center",children:['"',Cl,'"']})}),f.jsxs("div",{className:"flex flex-col gap-4",children:[f.jsx("button",{onClick:n,className:"flex items-center justify-center gap-3 w-full py-4 rounded-2xl border-2 border-[#E5C07B] text-[#E5C07B] font-serif font-semibold text-base hover:bg-[#E5C07B]/10 transition-all duration-300",children:t?f.jsxs(f.Fragment,{children:[f.jsx(Uk,{className:"w-5 h-5 text-green-400"}),f.jsx("span",{className:"text-green-400",children:"Copied!"})]}):f.jsxs(f.Fragment,{children:[f.jsx(Gk,{className:"w-5 h-5"}),"Copy Link"]})}),f.jsxs("button",{onClick:o,className:"flex items-center justify-center gap-3 w-full py-4 rounded-2xl border-2 border-[#E5C07B] text-[#E5C07B] font-serif font-semibold text-base hover:bg-[#E5C07B]/10 transition-all duration-300",children:[f.jsx(rw,{className:"w-5 h-5"}),"Send Text"]}),f.jsxs("button",{onClick:i,className:"flex items-center justify-center gap-3 w-full py-4 rounded-2xl bg-[#E5C07B] text-[#4A0404] font-serif font-bold text-base hover:bg-[#C9A55A] transition-all duration-300 shadow-md",children:[f.jsx(Vl,{className:"w-5 h-5"}),"Share via..."]})]})]}),f.jsxs(ie.div,{initial:{opacity:0,y:20},animate:{opacity:1,y:0},transition:{duration:.5,delay:.4},className:"bg-white rounded-3xl p-8 border border-[#E5C07B]/40 shadow-sm mb-10",children:[f.jsx("h3",{className:"font-display text-xl text-[#4A0404] text-center mb-2",children:"Install to Your Home Screen"}),f.jsx("p",{className:"font-serif text-[#6B6B6B] text-sm text-center mb-6",children:"Access the app instantly — no App Store needed."}),f.jsx("ol",{className:"space-y-5",children:[{step:"1",text:"Tap the Menu or Share arrow in your browser."},{step:"2",text:'Select "Add to Home Screen" or "Install App".'},{step:"3",text:"Open the Gold Seal from your home screen and enjoy!"}].map(({step:l,text:u})=>f.jsxs("li",{className:"flex items-start gap-4",children:[f.jsx("span",{className:"w-8 h-8 rounded-full bg-[#4A0404] text-[#E5C07B] font-bold font-display flex items-center justify-center shrink-0 text-sm",children:l}),f.jsx("p",{className:"font-serif text-[#3C3C3C] text-sm leading-relaxed pt-1",children:u})]},l))})]}),f.jsxs(ie.div,{initial:{opacity:0},animate:{opacity:1},transition:{delay:.7,duration:.6},className:"text-center mt-4 mb-16",children:[f.jsx("p",{className:"font-display text-lg md:text-xl text-[#4A0404]/70 italic",children:'"Let your light shine before others, that they may see your good deeds and glorify your Father in heaven."'}),f.jsx("p",{className:"mt-2 text-sm text-[#A0A0A0] font-serif",children:"— Matthew 5:16"})]}),f.jsx("div",{className:"text-center",children:f.jsx("p",{className:"font-serif text-xs text-[#E5C07B]",children:"© 2026 Kingdom Mandate Ministry | Built by the Grace of God, for the Glory of God"})})]})})]})}const k0={Healing:{introduction:`God's heart for healing runs like a golden thread through every page of Scripture. From the earliest promises of the Old Testament to the ministry of Jesus in the Gospels, we see a God who is not indifferent to pain — He is moved by it. He draws near to the brokenhearted. He binds up wounds. He restores what sickness, loss, and grief have taken. Healing, in the biblical sense, is not only physical; it is the wholeness of a person — body, mind, and spirit — being brought back into alignment with God's loving design.

You don't have to pretend you're okay to come to God for healing. He already knows what you're carrying. What He asks is simply that you come — with your real pain, your honest questions, your tired heart. The Scriptures below are not formulas; they are windows into the character of a God who heals because it is in His nature to restore. Let these verses be a comfort and an invitation today.`,verses:[{reference:"Psalm 147:3",text:"He heals the brokenhearted and binds up their wounds."},{reference:"Jeremiah 17:14",text:"Heal me, Lord, and I will be healed; save me and I will be saved, for you are the one I praise."},{reference:"James 5:15",text:"And the prayer offered in faith will make the sick person well; the Lord will raise them up."},{reference:"Psalm 103:2-3",text:"Praise the Lord, my soul, and forget not all his benefits — who forgives all your sins and heals all your diseases."},{reference:"Matthew 11:28",text:"Come to me, all you who are weary and burdened, and I will give you rest."},{reference:"Isaiah 53:5",text:"But he was pierced for our transgressions, he was crushed for our iniquities; the punishment that brought us peace was on him, and by his wounds we are healed."},{reference:"Exodus 15:26",text:"I am the Lord, who heals you."},{reference:"Psalm 30:2",text:"Lord my God, I called to you for help, and you healed me."},{reference:"Revelation 21:4",text:"He will wipe every tear from their eyes. There will be no more death or mourning or crying or pain, for the old order of things has passed away."},{reference:"3 John 1:2",text:"Dear friend, I pray that you may enjoy good health and that all may go well with you, even as your soul is getting along well."}],reflection:`Healing rarely happens all at once. More often, it is a slow and tender process — like a wound that closes gradually from the inside out. This is not a sign that God is absent or that your faith is lacking; it is simply the nature of how deep restoration works. God is not in a hurry with you. He is thorough. He heals not just symptoms but the roots beneath them.

In the waiting, the most important thing you can do is stay in His presence. Bring your pain to Him honestly and often. Let the Psalms become your vocabulary for grief. Let the promises above become anchors when doubt creeps in. And when healing comes — even partially, even in unexpected forms — recognize it and give thanks. Gratitude opens our eyes to the ways God is already at work.

You are not defined by what has broken you. You are defined by the God who calls Himself your Healer. Whatever you are facing today — physical illness, emotional wounds, grief, addiction, the aftermath of trauma — He sees it, He cares about it, and He is already at work in it. You can trust Him with the parts of you that feel beyond repair.`},Forgiveness:{introduction:`Forgiveness is one of the most countercultural teachings in all of Scripture. In a world that says 'protect yourself, keep score, and make people earn your trust back,' God says something entirely different: forgive as you have been forgiven — freely, completely, and without a running record of wrongs. This is not a small ask. It is one of the most difficult and most liberating things a human being can do.

The foundation of Christian forgiveness is not human willpower but divine example. Before God asks us to forgive others, He demonstrates what forgiveness looks like — in the cross, in the welcome He gives to the prodigal, in the words of Jesus from the cross: 'Father, forgive them.' We forgive not because it's easy or because the other person deserves it, but because we ourselves have been shown a mercy we did not deserve. These Scriptures below are an invitation into that freedom.`,verses:[{reference:"Ephesians 4:32",text:"Be kind and compassionate to one another, forgiving each other, just as in Christ God forgave you."},{reference:"1 John 1:9",text:"If we confess our sins, he is faithful and just and will forgive us our sins and purify us from all unrighteousness."},{reference:"Colossians 3:13",text:"Bear with each other and forgive one another if any of you has a grievance against someone. Forgive as the Lord forgave you."},{reference:"Matthew 6:14",text:"For if you forgive other people when they sin against you, your heavenly Father will also forgive you."},{reference:"Psalm 103:12",text:"As far as the east is from the west, so far has he removed our transgressions from us."},{reference:"Isaiah 43:25",text:"I, even I, am he who blots out your transgressions, for my own sake, and remembers your sins no more."},{reference:"Luke 6:37",text:"Do not judge, and you will not be judged. Do not condemn, and you will not be condemned. Forgive, and you will be forgiven."},{reference:"Romans 8:1",text:"Therefore, there is now no condemnation for those who are in Christ Jesus."},{reference:"Micah 7:18-19",text:"Who is a God like you, who pardons sin and forgives the transgression of the remnant of his inheritance? You do not stay angry forever but delight to show mercy."},{reference:"Proverbs 17:9",text:"Whoever would foster love covers over an offense, but whoever repeats the matter separates close friends."}],reflection:`Forgiving someone does not mean pretending what happened was acceptable, or that trust is automatically restored. It means releasing the debt — choosing not to carry the wound as a weapon, and not letting the hurt define you going forward. It is, above all, an act you do for your own freedom as much as for the other person. Unforgiveness is a prison that traps the one holding the key.

The good news is that you don't have to manufacture forgiveness on your own. You can pray an honest prayer: 'Lord, I don't feel like forgiving this person. But I choose to. Help me.' That choice — even without the feeling — is enough to begin. God meets us in the act of the will, and the feeling often follows in time.

And don't forget to receive forgiveness for yourself. Many people are far more willing to extend forgiveness to others than to accept it for their own failures and regrets. But God's word is clear: your sins are removed as far as the east is from the west. There is no condemnation for those who are in Christ. Today, you are invited to live in the freedom that complete forgiveness provides — both given and received.`},Strength:{introduction:`The strength God offers is unlike anything the world promotes. The world says strength comes from discipline, self-belief, and refusing to show weakness. God says something far more surprising: His strength is made perfect in weakness. It shows up most powerfully precisely when we have run out of our own resources. This is not a consolation prize — it is one of the most profound spiritual realities in all of Scripture.

When we are exhausted, afraid, overwhelmed, or at the end of ourselves, we are in exactly the right position to receive divine strength. The invitation throughout the Bible is not to 'try harder' but to 'wait on the Lord,' to 'be strong in His might,' and to 'take courage, knowing He is with you.' The verses below are not motivational slogans — they are trustworthy promises from a God who has never failed to strengthen those who called on Him.`,verses:[{reference:"Isaiah 40:31",text:"But those who hope in the Lord will renew their strength. They will soar on wings like eagles; they will run and not grow weary, they will walk and not be faint."},{reference:"Philippians 4:13",text:"I can do all this through him who gives me strength."},{reference:"Psalm 28:7",text:"The Lord is my strength and my shield; my heart trusts in him, and he helps me. My heart leaps for joy, and with my song I praise him."},{reference:"Joshua 1:9",text:"Have I not commanded you? Be strong and courageous. Do not be afraid; do not be discouraged, for the Lord your God will be with you wherever you go."},{reference:"2 Corinthians 12:9",text:"But he said to me, 'My grace is sufficient for you, for my power is made perfect in weakness.'"},{reference:"Ephesians 6:10",text:"Finally, be strong in the Lord and in his mighty power."},{reference:"Psalm 46:1",text:"God is our refuge and strength, an ever-present help in trouble."},{reference:"Nehemiah 8:10",text:"Do not grieve, for the joy of the Lord is your strength."},{reference:"Isaiah 41:10",text:"So do not fear, for I am with you; do not be dismayed, for I am your God. I will strengthen you and help you; I will uphold you with my righteous right hand."},{reference:"2 Timothy 1:7",text:"For the Spirit God gave us does not make us timid, but gives us power, love and self-discipline."}],reflection:`True strength is not the absence of weakness — it is weakness that has been surrendered to God. The strongest people in Scripture are not those who never struggled; they are those who knew where to go when they did. David ran to God in fear. Paul boasted in his weakness. Elijah collapsed under a tree and was fed by an angel. None of them were disqualified by their limits — they were met by God in them.

When you are facing something that feels too heavy, too long, or too uncertain, the invitation is not to find a deeper reserve of willpower. It is to wait on the Lord — to bring your emptiness to Him and trust that He will fill it. This kind of waiting is not passive; it is active trust. It says: I believe You are going to come through, and I am going to hold on until You do.

Let these scriptures become anchors in your day. When fear speaks loudly, respond with Joshua 1:9. When exhaustion sets in, return to Isaiah 40:31. When you feel disqualified by your weakness, let 2 Corinthians 12:9 remind you that this is exactly where God's power shows up. You are not alone in this. You are held, strengthened, and accompanied by a God whose power knows no limit.`}},LR="nWBoXJdS48fQxR6SIuBLp",IR="https://rest.api.bible/v1",BR="de4e12af7f28f599-01",e1="bc_topic_";function OR(t){try{const e=localStorage.getItem(`${e1}${t}`);return e?JSON.parse(e):null}catch{return null}}function MR(t,e){try{localStorage.setItem(`${e1}${t}`,JSON.stringify(e))}catch{}}function DR({topic:t,onBack:e}){var g;const[n,o]=E.useState(null),[i,l]=E.useState(!0),[u,d]=E.useState(!1);E.useEffect(()=>{p()},[t.name]);const p=async()=>{var A;if(k0[t.name]){o(k0[t.name]),l(!1),d(!1);return}const v=OR(t.name);if(v){o(v),l(!1),d(!1);return}l(!0),o(null),d(!1);const x=await fetch(`${IR}/bibles/${BR}/search?query=${encodeURIComponent(t.name)}&limit=10&sort=relevance`,{headers:{"api-key":LR}});if(!x.ok){d(!0),l(!1);return}const C=((A=(await x.json()).data)==null?void 0:A.verses)||[];if(!C.length){d(!0),l(!1);return}const S=C.slice(0,10).map(M=>({reference:M.reference,text:(M.content||M.text||"").replace(/<[^>]+>/g,"").replace(/\s+/g," ").trim()})),b={introduction:`The theme of ${t.name} runs throughout the Bible, from the Old Testament to the New. Below you will find ten scriptures that speak directly to this theme. Let these words minister to your heart and draw you closer to God's truth.`,verses:S,reflection:`As you meditate on these scriptures, ask the Holy Spirit to bring them alive in your daily life. God's Word is living and active — and His promises concerning ${t.name} are for you today.`};MR(t.name,b),o(b),l(!1)},m=t.icon;return f.jsxs(ie.div,{initial:{opacity:0,y:16},animate:{opacity:1,y:0},children:[f.jsxs("button",{onClick:e,className:"flex items-center gap-1.5 text-sage mb-6